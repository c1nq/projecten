#Requires -RunAsAdministrator
<#
.SYNOPSIS
    Network Scanner - c1nq
.DESCRIPTION
    Scant het netwerk en toont alle actieve apparaten met hostname, IP, MAC en ping tijd.
#>

$LogFile = "$PSScriptRoot\network-scan.log"

function Write-Log {
    param($Message, $Level = "INFO")
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $logEntry = "[$timestamp] [$Level] $Message"
    Add-Content -Path $LogFile -Value $logEntry
}

function Get-LocalSubnet {
    $ip = (Get-NetIPAddress -AddressFamily IPv4 | Where-Object { 
        $_.IPAddress -notlike "127.*" -and $_.IPAddress -notlike "169.*" -and $_.PrefixOrigin -eq "Dhcp"
    } | Select-Object -First 1).IPAddress
    
    if (-not $ip) {
        $ip = (Get-NetIPAddress -AddressFamily IPv4 | Where-Object { 
            $_.IPAddress -notlike "127.*" -and $_.IPAddress -notlike "169.*"
        } | Select-Object -First 1).IPAddress
    }
    
    $subnet = $ip -replace "\.\d+$", ""
    return $subnet, $ip
}

function Get-MACAddress {
    param($IP)
    $arp = arp -a $IP 2>$null
    if ($arp) {
        $mac = ($arp | Select-String "([0-9a-f]{2}[-:]){5}[0-9a-f]{2}" -AllMatches).Matches.Value | Select-Object -First 1
        if ($mac) { return $mac } else { return "Onbekend" }
    }
    return "Onbekend"
}

function Start-NetworkScan {
    param($Subnet)
    
    Clear-Host
    Write-Host "=================================" -ForegroundColor Red
    Write-Host "    c1nq - Network Scanner       " -ForegroundColor Red
    Write-Host "    Subnet: $Subnet.0/24          " -ForegroundColor Red
    Write-Host "    $(Get-Date -Format 'dd-MM-yyyy HH:mm:ss')    " -ForegroundColor Red
    Write-Host "=================================" -ForegroundColor Red
    Write-Host ""
    Write-Host "Scannen..." -ForegroundColor Yellow
    Write-Host ""

    $results = @()
    $jobs = @()

    # Ping alle IPs tegelijk via jobs
    1..254 | ForEach-Object {
        $ip = "$Subnet.$_"
        $jobs += Start-Job -ScriptBlock {
            param($ip)
            $ping = Test-Connection -ComputerName $ip -Count 1 -TimeoutSeconds 1 -ErrorAction SilentlyContinue
            if ($ping) {
                [PSCustomObject]@{
                    IP       = $ip
                    PingTime = $ping.Latency
                }
            }
        } -ArgumentList $ip
    }

    # Wacht op alle jobs
    $total = $jobs.Count
    $done = 0
    foreach ($job in $jobs) {
        $done++
        $pct = [math]::Round(($done / $total) * 100, 0)
        Write-Progress -Activity "Netwerk scannen..." -Status "$pct% ($done/$total)" -PercentComplete $pct
        $result = Receive-Job -Job $job -Wait
        if ($result) { $results += $result }
        Remove-Job -Job $job
    }
    Write-Progress -Completed -Activity "Scan klaar"

    # Verrijk resultaten met hostname en MAC
    $enriched = foreach ($r in $results | Sort-Object { [version]$_.IP }) {
        $hostname = try { [System.Net.Dns]::GetHostEntry($r.IP).HostName } catch { "Onbekend" }
        $mac = Get-MACAddress -IP $r.IP

        [PSCustomObject]@{
            IP       = $r.IP
            Hostname = $hostname
            MAC      = $mac
            Ping     = "$($r.PingTime)ms"
            Status   = "Online"
        }
    }

    # Toon resultaten
    Write-Host ""
    Write-Host "=================================" -ForegroundColor Red
    Write-Host "  Gevonden apparaten: $($enriched.Count)" -ForegroundColor Red
    Write-Host "=================================" -ForegroundColor Red
    Write-Host ""
    
    $enriched | Format-Table -AutoSize

    # Sla op als CSV
    $reportFile = "$PSScriptRoot\scan-$(Get-Date -Format 'yyyyMMdd-HHmmss').csv"
    $enriched | Export-Csv -Path $reportFile -NoTypeInformation -Encoding UTF8
    
    Write-Log "Scan uitgevoerd op subnet $Subnet.0/24 — $($enriched.Count) apparaten gevonden"
    Write-Host "Rapport opgeslagen: $reportFile" -ForegroundColor Gray
}

function Show-Menu {
    Clear-Host
    Write-Host "=================================" -ForegroundColor Red
    Write-Host "    c1nq - Network Scanner       " -ForegroundColor Red
    Write-Host "=================================" -ForegroundColor Red
    Write-Host ""
    Write-Host "  [1] Automatisch scannen (eigen subnet)" -ForegroundColor White
    Write-Host "  [2] Handmatig subnet invoeren" -ForegroundColor White
    Write-Host "  [3] Vorige scans bekijken" -ForegroundColor White
    Write-Host "  [0] Afsluiten" -ForegroundColor White
    Write-Host ""
}

# Main
Write-Log "Network Scanner gestart door $env:USERNAME"

do {
    Show-Menu
    $choice = Read-Host "Keuze"

    switch ($choice) {
        "1" {
            $subnet, $myIP = Get-LocalSubnet
            Write-Host "Eigen IP: $myIP | Subnet: $subnet.0/24" -ForegroundColor Yellow
            Start-NetworkScan -Subnet $subnet
        }
        "2" {
            $subnet = Read-Host "Subnet invoeren (bijv. 192.168.1)"
            Start-NetworkScan -Subnet $subnet
        }
        "3" {
            Get-ChildItem -Path $PSScriptRoot -Filter "scan-*.csv" | 
                Select-Object Name, CreationTime, Length | 
                Format-Table -AutoSize
        }
        "0" { Write-Log "Network Scanner afgesloten"; break }
    }

    if ($choice -ne "0") { Read-Host "`nDruk Enter om door te gaan" }

} while ($choice -ne "0")
